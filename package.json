{
  "name": "aluguel-materiais",
  "version": "1.0.0",
  "description": "Controle de aluguel/emprestimo de materiais de comunicacao e brindes para cooperativa. Banco de dados em CSV, sem servidor externo.",
  "main": "src/main/main.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --runInBand",
    "start": "npm test && electron .",
    "dev": "npm test && electron . --enable-logging",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:exe": "electron-builder --win nsis",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "build": {
    "appId": "com.cooperativa.aluguelmateriais",
    "productName": "Gestão de Materiais",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
