{
  "name": "aluguel-materiais",
  "version": "1.0.0",
  "description": "Controle de aluguel/emprestimo de materiais de comunicacao e brindes para cooperativa. Banco de dados em CSV, sem servidor externo.",
  "main": "src/main/main.js",
  "scripts": {
    "test": "jest --runInBand",
    "start": "npm test && electron .",
    "dev": "npm test && electron . --enable-logging",
    "build:portable": "electron-builder --win portable",
    "build:exe": "electron-builder --win nsis",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^30.4.2"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "build": {
    "appId": "com.cooperativa.aluguelmateriais",
    "productName": "Aluguel de Materiais",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "AluguelDeMateriais-portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "AluguelDeMateriais-setup-${version}.${ext}"
    }
  }
}
